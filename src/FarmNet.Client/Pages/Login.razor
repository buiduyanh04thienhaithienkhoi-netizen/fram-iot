@page "/login"
@layout FarmNet.Client.Layout.LoginLayout
@inject AuthApiService AuthService
@inject NavigationManager Nav

<div class="min-h-screen bg-gradient-to-br from-green-600 to-green-900 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-8">
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-leaf text-green-600 text-3xl"></i>
            </div>
            <h1 class="text-2xl font-bold text-gray-800">FarmNet</h1>
            <p class="text-gray-500 text-sm mt-1">Quản lý quy trình sản xuất nông nghiệp</p>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <Alert Color="Color.Danger" Visible Margin="Margin.Is4.FromBottom">
                <AlertMessage>@_errorMessage</AlertMessage>
            </Alert>
        }

        <Validations @ref="_validations" Mode="ValidationMode.Manual" Model="@_loginModel" HandlerType="typeof(FluentValidationHandler)" ValidateOnLoad="false">
            <Validation>
                <Field>
                    <FieldLabel>Email</FieldLabel>
                    <TextInput @bind-Value="_loginModel.Email" Placeholder="email@farmnet.vn">
                        <Feedback>
                            <ValidationError />
                        </Feedback>
                    </TextInput>
                </Field>
            </Validation>
            <Validation>
                <Field>
                    <FieldLabel>Mật khẩu</FieldLabel>
                    <TextInput @bind-Value="_loginModel.MatKhau" Role="TextRole.Password" Placeholder="••••••••">
                        <Feedback>
                            <ValidationError />
                        </Feedback>
                    </TextInput>
                </Field>
            </Validation>
        </Validations>

        <Button Color="Color.Success" Block Clicked="HandleLogin" Loading="@_loading" Margin="Margin.Is4.FromTop" Size="Size.Large">
            <i class="fas fa-sign-in-alt mr-2"></i> Đăng nhập
        </Button>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }

    private readonly LoginRequest _loginModel = new();
    private string? _errorMessage;
    private bool _loading;
    private Validations? _validations;

    private async Task HandleLogin()
    {
        if (_validations is not null && !await _validations.ValidateAll()) return;

        _loading = true;
        _errorMessage = null;

        var (success, error) = await AuthService.LoginAsync(_loginModel);
        if (success)
        {
            var target = string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl;
            Nav.NavigateTo(target, replace: true);
        }
        else
            _errorMessage = error;

        _loading = false;
    }
}
