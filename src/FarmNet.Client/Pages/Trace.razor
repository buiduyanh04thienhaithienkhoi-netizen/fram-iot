@page "/trace/{MaLo}"
@layout FarmNet.Client.Layout.LoginLayout
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Truy xuất nguồn gốc - @MaLo</PageTitle>

<div class="min-h-screen bg-gradient-to-b from-green-50 to-white">
    <div class="bg-green-700 text-white py-6 px-4">
        <div class="max-w-2xl mx-auto flex items-center gap-3">
            <i class="fas fa-leaf text-green-300 text-2xl"></i>
            <div>
                <h1 class="text-xl font-bold">FarmNet</h1>
                <p class="text-green-200 text-sm">Truy xuất nguồn gốc nông sản</p>
            </div>
        </div>
    </div>

    <div class="max-w-2xl mx-auto p-4 space-y-6">
        @if (_loading)
        {
            <div class="flex flex-col items-center py-16">
                <div class="w-10 h-10 border-4 border-green-500 border-t-transparent rounded-full animate-spin mb-4"></div>
                <p class="text-gray-500">Đang tải thông tin lô @MaLo...</p>
            </div>
        }
        else if (_data == null)
        {
            <div class="text-center py-16">
                <i class="fas fa-box-open text-gray-300 text-5xl mb-4"></i>
                <p class="text-gray-500 text-lg">Không tìm thấy thông tin lô sản phẩm</p>
                <p class="text-gray-400 text-sm mt-1">Mã lô: @MaLo</p>
            </div>
        }
        else
        {
            <div class="bg-white rounded-2xl shadow-sm border border-green-100 overflow-hidden">
                <div class="bg-gradient-to-r from-green-600 to-green-500 px-6 py-4">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center">
                            <i class="fas fa-seedling text-white text-xl"></i>
                        </div>
                        <div>
                            <h2 class="text-xl font-bold text-white">@_data.TenSanPham</h2>
                            <p class="text-green-100 text-xs font-mono">Mã lô: @_data.MaLo</p>
                        </div>
                        <div class="ml-auto">
                            <span class="inline-flex items-center gap-1.5 bg-white/20 text-white text-xs font-medium px-3 py-1 rounded-full">
                                <i class="fas fa-circle text-green-300 text-[6px]"></i>
                                @_data.TrangThai
                            </span>
                        </div>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-0 divide-x divide-y divide-gray-100 text-sm">
                    <div class="p-4">
                        <p class="text-gray-400 text-xs mb-1">Trang trại</p>
                        <p class="font-semibold text-gray-800">@_data.TenFarm</p>
                    </div>
                    <div class="p-4">
                        <p class="text-gray-400 text-xs mb-1">Ngày bắt đầu</p>
                        <p class="font-medium text-gray-700">@_data.NgayTao.ToString("dd/MM/yyyy")</p>
                    </div>
                    <div class="p-4 col-span-2">
                        <p class="text-gray-400 text-xs mb-1">Địa chỉ</p>
                        <p class="text-gray-700">@_data.DiaChiFarm</p>
                    </div>
                    @if (_data.ThuHoach != null)
                    {
                        <div class="p-4">
                            <p class="text-gray-400 text-xs mb-1">Ngày thu hoạch</p>
                            <p class="font-medium text-green-700">@_data.ThuHoach.NgayThuHoach.ToString("dd/MM/yyyy")</p>
                        </div>
                        <div class="p-4">
                            <p class="text-gray-400 text-xs mb-1">Sản lượng</p>
                            <p class="font-semibold text-gray-800">@_data.ThuHoach.TrongLuong kg</p>
                        </div>
                    }
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                <h3 class="font-bold text-gray-700 mb-6 flex items-center gap-2">
                    <i class="fas fa-route text-green-500"></i>Hành trình sản xuất (@_timeline.Count sự kiện)
                </h3>
                <div class="relative">
                    <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gray-100"></div>
                    <div class="space-y-0">
                        @for (int i = 0; i < _timeline.Count; i++)
                        {
                            var item = _timeline[i];
                            var isLast = i == _timeline.Count - 1;
                            <div class="relative flex items-start gap-4 @(isLast ? "" : "pb-6")">
                                <div class="relative z-10 w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 @item.DotClass">
                                    <i class="fas @item.Icon text-white text-xs"></i>
                                </div>
                                <div class="flex-1 min-w-0 pt-0.5">
                                    <div class="flex items-start justify-between gap-2">
                                        <p class="font-semibold text-gray-800 text-sm">@item.Title</p>
                                        <span class="text-xs text-gray-400 flex-shrink-0">@item.Date.ToString("dd/MM/yyyy")</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.Detail))
                                    {
                                        <p class="text-xs text-gray-500 mt-0.5">@item.Detail</p>
                                    }
                                    @if (!string.IsNullOrEmpty(item.SubDetail))
                                    {
                                        <p class="text-xs text-gray-400 mt-0.5 italic">@item.SubDetail</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Blockchain Verification -->
            <div class="bg-white rounded-2xl shadow-sm border overflow-hidden
                        @(_verify == null ? "border-gray-200" : _verify.ToanVen ? "border-green-200" : "border-red-200")">

                @if (_verifying)
                {
                    <div class="p-6 flex flex-col items-center gap-3">
                        <div class="w-8 h-8 border-4 border-indigo-400 border-t-transparent rounded-full animate-spin"></div>
                        <p class="text-gray-500 text-sm">Đang kiểm tra tính xác thực...</p>
                    </div>
                }
                else if (_verify != null)
                {
                    @if (_verify.ToanVen)
                    {
                        <div class="bg-gradient-to-r from-green-500 to-emerald-500 px-6 py-5 text-white">
                            <div class="flex items-center gap-3">
                                <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-shield-alt text-2xl"></i>
                                </div>
                                <div>
                                    <h3 class="font-bold text-lg">Sản phẩm xác thực</h3>
                                    <p class="text-green-100 text-sm">
                                        @if (_verify.TongSoNgay > 0)
                                        {
                                            <span>Kiểm tra ngẫu nhiên @_verify.SoNgayKiemTra/@_verify.TongSoNgay ngày — dữ liệu không bị thay đổi.</span>
                                        }
                                        else
                                        {
                                            <span>Thông tin lô sản phẩm đã được ghi nhận trên blockchain.</span>
                                        }
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="bg-gradient-to-r from-red-500 to-rose-500 px-6 py-5 text-white">
                            <div class="flex items-center gap-3">
                                <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-exclamation-triangle text-2xl"></i>
                                </div>
                                <div>
                                    <h3 class="font-bold text-lg">Phát hiện dữ liệu bị thay đổi</h3>
                                    <p class="text-red-100 text-sm">
                                        @_verify.SoNgayBiThayDoi/@_verify.SoNgayKiemTra ngày kiểm tra có dữ liệu không khớp.
                                    </p>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="p-4">
                        <div class="space-y-2 mb-3">
                            <div class="flex items-center gap-3 p-3 rounded-xl text-sm @StatusBg(_verify.TaoLoStatus)">
                                <i class="fas @StatusIcon(_verify.TaoLoStatus) flex-shrink-0"></i>
                                <span class="flex-1 font-medium text-gray-800">Tạo lô sản phẩm</span>
                                <span class="text-xs font-medium @StatusColor(_verify.TaoLoStatus)">@StatusLabel(_verify.TaoLoStatus)</span>
                            </div>
                            @if (_verify.ThuHoachStatus.HasValue)
                            {
                                <div class="flex items-center gap-3 p-3 rounded-xl text-sm @StatusBg(_verify.ThuHoachStatus.Value)">
                                    <i class="fas @StatusIcon(_verify.ThuHoachStatus.Value) flex-shrink-0"></i>
                                    <span class="flex-1 font-medium text-gray-800">Thu hoạch</span>
                                    <span class="text-xs font-medium @StatusColor(_verify.ThuHoachStatus.Value)">@StatusLabel(_verify.ThuHoachStatus.Value)</span>
                                </div>
                            }
                        </div>

                        @if (_verify.ChiTietNgay.Count > 0)
                        {
                            <button class="w-full flex items-center justify-between text-sm text-gray-600 hover:text-gray-800 transition-colors py-2"
                                    @onclick="() => _showDetail = !_showDetail">
                                <span class="flex items-center gap-2">
                                    <i class="fas fa-calendar-check text-indigo-400"></i>
                                    Chi tiết kiểm tra theo ngày (@_verify.SoNgayKiemTra/@_verify.TongSoNgay ngày)
                                </span>
                                <i class="fas @(_showDetail ? "fa-chevron-up" : "fa-chevron-down") text-xs"></i>
                            </button>

                            @if (_showDetail)
                            {
                                <div class="space-y-2 mt-2">
                                    @foreach (var item in _verify.ChiTietNgay)
                                    {
                                        <div class="flex items-center gap-3 p-3 rounded-xl text-sm @StatusBg(item.TrangThai)">
                                            <i class="fas @StatusIcon(item.TrangThai) flex-shrink-0"></i>
                                            <div class="flex-1 min-w-0">
                                                <span class="font-medium text-gray-800">@item.Ngay</span>
                                                <span class="text-xs text-gray-400 ml-2">@item.SoNhatKy nhật ký · @item.SoCamBien cảm biến</span>
                                            </div>
                                            <span class="text-xs font-medium flex-shrink-0 @StatusColor(item.TrangThai)">
                                                @StatusLabel(item.TrangThai)
                                            </span>
                                        </div>
                                    }
                                </div>

                                <button class="w-full flex items-center justify-between text-xs text-gray-400 hover:text-gray-600 transition-colors py-2 mt-3 border-t border-gray-100"
                                        @onclick="() => _showTechnical = !_showTechnical">
                                    <span class="flex items-center gap-1">
                                        <i class="fas fa-code"></i>
                                        Xem mã kỹ thuật
                                    </span>
                                    <i class="fas @(_showTechnical ? "fa-chevron-up" : "fa-chevron-down") text-xs"></i>
                                </button>

                                @if (_showTechnical)
                                {
                                    <div class="space-y-2 mt-1">
                                        @foreach (var item in _verify.ChiTietNgay)
                                        {
                                            <div class="p-3 bg-gray-50 rounded-lg text-xs font-mono space-y-1">
                                                <p class="text-gray-500 font-sans font-medium text-sm">@item.Ngay</p>
                                                <div class="flex items-center gap-2">
                                                    <span class="text-gray-400 font-sans w-20 flex-shrink-0">Hash lưu:</span>
                                                    <span class="text-gray-600 truncate">@item.StoredHash</span>
                                                </div>
                                                <div class="flex items-center gap-2">
                                                    <span class="text-gray-400 font-sans w-20 flex-shrink-0">Hash tính:</span>
                                                    <span class="@(item.IsMatch ? "text-green-600" : "text-red-600") truncate">@item.ComputedHash</span>
                                                </div>
                                                @if (!string.IsNullOrEmpty(item.TxHash))
                                                {
                                                    <div class="flex items-center gap-2">
                                                        <span class="text-gray-400 font-sans w-20 flex-shrink-0">TxHash:</span>
                                                        <span class="text-indigo-600 truncate">@item.TxHash</span>
                                                        <button class="text-gray-400 hover:text-indigo-600 flex-shrink-0"
                                                                @onclick='() => CopyToClipboard(item.TxHash!)' title="Sao chép">
                                                            <i class="fas @(_copiedHash == item.TxHash ? "fa-check text-green-500" : "fa-copy")"></i>
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        }
                    </div>
                }
                else
                {
                    <div class="p-6 text-center">
                        <p class="text-gray-400 text-sm">Không thể tải dữ liệu xác thực</p>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string MaLo { get; set; } = "";
    private TraceabilityDto? _data;
    private BlockchainVerifyResultDto? _verify;
    private bool _loading = true;
    private bool _verifying = true;
    private bool _showDetail;
    private bool _showTechnical;
    private string? _copiedHash;
    private List<TimelineItem> _timeline = [];

    private record TimelineItem(DateTime Date, string Title, string Detail, string SubDetail, string Icon, string DotClass);

    protected override async Task OnInitializedAsync()
    {
        var response = await Http.GetAsync($"api/public/trace/{MaLo}");
        if (response.IsSuccessStatusCode)
        {
            _data = await response.Content.ReadFromJsonAsync<TraceabilityDto>();
            if (_data != null) BuildTimeline();
        }
        _loading = false;
        StateHasChanged();

        if (_data != null)
        {
            var verifyResponse = await Http.GetAsync($"api/public/trace/{MaLo}/verify");
            if (verifyResponse.IsSuccessStatusCode)
                _verify = await verifyResponse.Content.ReadFromJsonAsync<BlockchainVerifyResultDto>();
        }
        _verifying = false;
    }

    private void BuildTimeline()
    {
        _timeline.Clear();

        _timeline.Add(new TimelineItem(
            _data!.NgayTao, "Lô sản phẩm được tạo", $"Tại {_data.TenFarm}", _data.DiaChiFarm, "fa-seedling", "bg-green-500"));

        foreach (var log in _data.NhatKyCanhTac.OrderBy(l => l.NgayThucHien))
        {
            _timeline.Add(new TimelineItem(
                log.NgayThucHien, log.HoatDong, log.GhiChu ?? "",
                !string.IsNullOrEmpty(log.TenNguoiThucHien) ? $"Thực hiện bởi: {log.TenNguoiThucHien}" : "",
                "fa-clipboard-list", "bg-blue-400"));
        }

        if (_data.ThuHoach != null)
        {
            _timeline.Add(new TimelineItem(
                _data.ThuHoach.NgayThuHoach, "Thu hoạch",
                $"Sản lượng: {_data.ThuHoach.TrongLuong} kg",
                string.IsNullOrEmpty(_data.ThuHoach.GhiChuChatLuong) ? "" : $"Chất lượng: {_data.ThuHoach.GhiChuChatLuong}",
                "fa-leaf", "bg-orange-500"));
        }

        _timeline = [.. _timeline.OrderBy(t => t.Date)];
    }

    private static string StatusLabel(VerifyStatus s) => s switch
    {
        VerifyStatus.HopLe => "Hợp lệ",
        VerifyStatus.ChuaXacNhan => "Chờ xác nhận",
        VerifyStatus.BiThayDoi => "Đã bị thay đổi",
        VerifyStatus.BlockchainKhongKhop => "Blockchain không khớp",
        VerifyStatus.KhongTruyCapBlockchain => "Không kết nối blockchain",
        _ => "Không xác định"
    };

    private static string StatusColor(VerifyStatus s) => s switch
    {
        VerifyStatus.HopLe => "text-green-600",
        VerifyStatus.ChuaXacNhan => "text-yellow-600",
        VerifyStatus.KhongTruyCapBlockchain => "text-orange-500",
        _ => "text-red-600"
    };

    private static string StatusBg(VerifyStatus s) => s switch
    {
        VerifyStatus.HopLe => "bg-green-50",
        VerifyStatus.ChuaXacNhan => "bg-yellow-50",
        _ => "bg-red-50"
    };

    private static string StatusIcon(VerifyStatus s) => s switch
    {
        VerifyStatus.HopLe => "fa-check-circle text-green-500",
        VerifyStatus.ChuaXacNhan => "fa-clock text-yellow-500",
        VerifyStatus.KhongTruyCapBlockchain => "fa-plug-circle-exclamation text-orange-400",
        _ => "fa-times-circle text-red-500"
    };

    private async Task CopyToClipboard(string text)
    {
        await JS.InvokeVoidAsync("copyToClipboard", text);
        _copiedHash = text;
        StateHasChanged();
        await Task.Delay(2000);
        _copiedHash = null;
        StateHasChanged();
    }
}
