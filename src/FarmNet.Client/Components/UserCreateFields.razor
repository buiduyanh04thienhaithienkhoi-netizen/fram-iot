<Validation>
    <Field>
        <FieldLabel RequiredIndicator>Họ tên</FieldLabel>
        <TextInput @bind-Value="Form.HoTen" Placeholder="Họ và tên đầy đủ">
            <Feedback><ValidationError /></Feedback>
        </TextInput>
    </Field>
</Validation>
<Validation>
    <Field>
        <FieldLabel RequiredIndicator>Email</FieldLabel>
        <TextInput @bind-Value="Form.Email" Placeholder="example@email.com">
            <Feedback><ValidationError /></Feedback>
        </TextInput>
    </Field>
</Validation>
<Validation>
    <Field>
        <FieldLabel RequiredIndicator>Mật khẩu</FieldLabel>
        <TextInput @bind-Value="Form.MatKhau" Role="TextRole.Password" Placeholder="Mật khẩu">
            <Feedback><ValidationError /></Feedback>
        </TextInput>
    </Field>
</Validation>
<Validation>
    <Field>
        <FieldLabel RequiredIndicator>Vai trò</FieldLabel>
        <Select TValue="string" @bind-Value="Form.VaiTro">
            <ChildContent>
                <SelectItem TValue="string" Value="@("Admin")">Quản trị viên</SelectItem>
                <SelectItem TValue="string" Value="@("FarmOwner")">Chủ trang trại</SelectItem>
                <SelectItem TValue="string" Value="@("Worker")">Nhân viên</SelectItem>
            </ChildContent>
            <Feedback><ValidationError /></Feedback>
        </Select>
    </Field>
</Validation>
<Field>
    <FieldLabel>Trang trại</FieldLabel>
    <Select TValue="Guid?" @bind-Value="Form.FarmId">
        <SelectItem TValue="Guid?" Value="@((Guid?)null)">-- Không thuộc trang trại --</SelectItem>
        @foreach (var farm in Farms)
        {
            <SelectItem TValue="Guid?" Value="@((Guid?)farm.Id)">@farm.Ten</SelectItem>
        }
    </Select>
</Field>

@code {
    [Parameter] public TaoNguoiDungRequest Form { get; set; } = new();
    [Parameter] public List<FarmDto> Farms { get; set; } = [];
}
