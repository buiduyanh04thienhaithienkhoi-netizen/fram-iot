<Validation>
    <Field>
        <FieldLabel RequiredIndicator>Họ tên</FieldLabel>
        <TextInput @bind-Value="Form.HoTen" Placeholder="Họ và tên đầy đủ">
            <Feedback><ValidationError /></Feedback>
        </TextInput>
    </Field>
</Validation>
<Validation>
    <Field>
        <FieldLabel RequiredIndicator>Email</FieldLabel>
        <TextInput @bind-Value="Form.Email" Placeholder="example@email.com">
            <Feedback><ValidationError /></Feedback>
        </TextInput>
    </Field>
</Validation>
<Field>
    <FieldLabel>Trang trại</FieldLabel>
    <Select TValue="Guid?" @bind-Value="Form.FarmId">
        <SelectItem TValue="Guid?" Value="@((Guid?)null)">-- Không thuộc trang trại --</SelectItem>
        @foreach (var farm in Farms)
        {
            <SelectItem TValue="Guid?" Value="@((Guid?)farm.Id)">@farm.Ten</SelectItem>
        }
    </Select>
</Field>
<Validation>
    <Field>
        <FieldLabel>Mật khẩu mới</FieldLabel>
        <FieldHelp>Để trống nếu không thay đổi</FieldHelp>
        <TextInput @bind-Value="Form.MatKhauMoi" Role="TextRole.Password" Placeholder="Mật khẩu mới">
            <Feedback><ValidationError /></Feedback>
        </TextInput>
    </Field>
</Validation>

@code {
    [Parameter] public CapNhatNguoiDungRequest Form { get; set; } = new();
    [Parameter] public List<FarmDto> Farms { get; set; } = [];
}
